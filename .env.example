# Yahoo Fantasy OAuth (把 oauth2.json 的內容整個貼進來，格式為 JSON 字串)
YAHOO_OAUTH_JSON={"access_token": "", "consumer_key": "", "consumer_secret": "", ...}

# Yahoo Fantasy 聯盟設定
YAHOO_LEAGUE_ID=
YAHOO_TEAM_ID=

# Gemini API
GEMINI_API_KEY=

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# Google Sheets（選填，留空則不寫入）
GOOGLE_SHEET_ID=
